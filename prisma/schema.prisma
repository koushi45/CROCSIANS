generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                      @id @default(cuid())
  accountName            String                      @unique
  passwordHash           String
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  sessions               Session[]
  crocsiansSave          CrocsiansSave?
  crocsiansCharacterIcon CrocsiansCharacterIcon?
  crocsiansSkillUsage    CrocsiansSkillUsage?
  crocsiansChatMessages  CrocsiansChatMessage[]
  crocsiansBaseOwnedInteractions   CrocsiansBaseInteraction[] @relation("CrocsiansBaseOwner")
  crocsiansBaseVisitorInteractions CrocsiansBaseInteraction[] @relation("CrocsiansBaseVisitor")
  crocsiansSocialFrom              CrocsiansSocialRelationship[] @relation("CrocsiansSocialFrom")
  crocsiansSocialTo                CrocsiansSocialRelationship[] @relation("CrocsiansSocialTo")
  crocsiansLearnedWords            CrocsiansCharacterWord[]
  crocsiansDailyWordTeaches        CrocsiansDailyWordTeach[]
  crocsiansSpokenConversations     CrocsiansConversationLog[] @relation("CrocsiansConversationSpeaker")
  crocsiansHeardConversations      CrocsiansConversationLog[] @relation("CrocsiansConversationListener")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum CrocsiansItemType {
  MATERIAL
  WEAPON
  ARMOR
  SUPPLY
}

enum CrocsiansMarketListingStatus {
  ACTIVE
  SOLD
  WITHDRAWN
}

model CrocsiansMarketListing {
  id             String                        @id @default(cuid())
  sellerId       String
  sellerName     String
  itemType       CrocsiansItemType
  itemId         Int
  itemName       String
  quantity       Int
  price          Int
  npcPrice       Int
  status         CrocsiansMarketListingStatus @default(ACTIVE)
  buyerId        String?
  buyerName      String?
  taxRate        Float?
  buyerPaid      Int?
  sellerClaimed  Boolean                       @default(false)
  createdAt      DateTime                      @default(now())
  soldAt         DateTime?
  withdrawnAt    DateTime?

  @@index([status, createdAt])
  @@index([sellerId, status])
}

model CrocsiansTradeLog {
  id         String             @id @default(cuid())
  listingId  String
  sellerId   String
  sellerName String
  buyerId    String
  buyerName  String
  itemType   CrocsiansItemType
  itemId     Int
  itemName   String
  quantity   Int
  price      Int
  taxRate    Float
  buyerPaid  Int
  taxAmount  Int
  createdAt  DateTime           @default(now())

  @@index([sellerId, createdAt])
  @@index([buyerId, createdAt])
  @@index([listingId])
}

model CrocsiansMarketSetting {
  id        Int      @id @default(1)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt
}

model CrocsiansSave {
  id        String   @id @default(cuid())
  userId    String   @unique
  version   Int      @default(1)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model CrocsiansCharacterIcon {
  id          String   @id @default(cuid())
  userId      String   @unique
  contentType String   @default("image/webp")
  data        Bytes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CrocsiansBaseInteraction {
  id            String    @id @default(cuid())
  ownerId       String
  visitorId     String
  liked         Boolean   @default(false)
  favorited     Boolean   @default(false)
  lastVisitedAt DateTime?
  lastHelpDate  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  owner         User      @relation("CrocsiansBaseOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  visitor       User      @relation("CrocsiansBaseVisitor", fields: [visitorId], references: [id], onDelete: Cascade)

  @@unique([ownerId, visitorId])
  @@index([ownerId, lastVisitedAt])
  @@index([visitorId, favorited])
}

model CrocsiansSocialRelationship {
  id                String   @id @default(cuid())
  fromUserId        String
  toUserId          String
  friendship        Int      @default(0)
  rivalry           Int      @default(0)
  romance           Int      @default(0)
  friendshipStage   Int      @default(0)
  rivalryStage      Int      @default(0)
  romanceStage      Int      @default(0)
  romanceActive     Boolean  @default(false)
  femaleRoleUserId  String?
  maleRoleUserId    String?
  breakupCount      Int      @default(0)
  married           Boolean  @default(false)
  marriedAt         DateTime?
  interactionCount  Int      @default(0)
  lastActivity      String?
  lastInteractionAt DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  fromUser          User     @relation("CrocsiansSocialFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser            User     @relation("CrocsiansSocialTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([fromUserId, updatedAt])
  @@index([toUserId, updatedAt])
}

model CrocsiansCharacterWord {
  id                String   @id @default(cuid())
  userId            String
  category          String
  word              String
  learnedFromUserId String?
  favorite          Boolean  @default(false)
  learnedAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, word])
  @@index([userId, category, learnedAt])
}

model CrocsiansConversationLog {
  id                String   @id @default(cuid())
  speakerId         String
  listenerId        String
  category          String
  word              String
  message           String
  eventType         String   @default("conversation")
  relationshipKind  String?
  relationshipStage Int?
  createdAt         DateTime @default(now())
  speaker           User     @relation("CrocsiansConversationSpeaker", fields: [speakerId], references: [id], onDelete: Cascade)
  listener          User     @relation("CrocsiansConversationListener", fields: [listenerId], references: [id], onDelete: Cascade)

  @@index([speakerId, createdAt])
  @@index([listenerId, createdAt])
}

model CrocsiansDailyWordTeach {
  id        String   @id @default(cuid())
  userId    String
  dateKey   String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([dateKey])
}

model CrocsiansSkillUsage {
  id        String    @id @default(cuid())
  userId    String    @unique
  uses      Json      @default("{}")
  resetAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resetAt])
}

model CrocsiansChatMessage {
  id            String   @id @default(cuid())
  userId        String
  map           String
  characterName String
  job           String
  level         Int
  text          String
  imageData     Bytes?
  imageContentType String?
  imageExpiresAt DateTime?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([map, createdAt])
  @@index([userId, createdAt])
  @@index([imageExpiresAt])
}
